# ===== Banner 生图工具 - 环境变量配置 =====
#
# 复制此文件为 .env 并填入真实值:
#   cp .env.example .env
#
# 支持的环境变量 (按优先级排序):

# ---- 图像生成 ----

# DashScope 通义万相 API Key (用于 wan2.x 系列模型))
DASHSCOPE_API_KEY=sk-your-key-here

# 兼容 OpenAI 接口的 API Key (用于 gpt-image-1 等模型)
# 优先级: NEW_API_KEY > OPENAI_API_KEY > IMAGE_API_KEY
NEW_API_KEY=sk-your-key-here
OPENAI_API_KEY=sk-your-key-here
IMAGE_API_KEY=sk-your-key-here

# API 基础地址 (用于自定义 OpenAI-compatible 代理)
# 默认: https://api.openai.com/v1
IMAGE_API_BASE_URL=https://api.openai.com/v1

# ---- PocketBase 相关 ----

# PocketBase 外部可访问的地址 (用于生成图片 URL)
# 默认: http://127.0.0.1:8090
PB_BASE_URL=http://127.0.0.1:8090

# PocketBase 数据目录
# 默认: ./pb_data
PB_DATA_DIR=./pb_data

# ---- AI 打分 (可选) ----

# 打分使用与生图相同的 API Key 配置
# 模型选择在 UI 中通过 model_configs collection 管理
# 默认打分模型: gpt-4o
