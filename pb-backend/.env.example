# =============================================
# Banner-PB 后端环境变量
# 复制此文件为 .env 并填写真实值
# =============================================

# API 基础地址
IMAGE_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# API Key（任选一个服务）
DASHSCOPE_API_KEY=sk-your-dashscope-key
# 或
OPENAI_API_KEY=sk-your-openai-key
# 或
NEW_API_KEY=sk-your-new-api-key

# 生成参数
IMAGE_API_CONCURRENCY=1
IMAGE_API_TIMEOUT_MS=600000
IMAGE_API_RETRIES=1
